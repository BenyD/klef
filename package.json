{
  "name": "klef",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Personal, zero-knowledge, end-to-end-encrypted .env sync. Self-hostable on Cloudflare.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && pnpm run prerender",
    "prerender": "vite build --config vite.prerender.config.ts --logLevel warn && node dist/prerender/prerender.js",
    "preview": "vite preview",
    "og": "node scripts/og.ts",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "better-auth generate --config ./scripts/auth-cli.ts --output ./db/migrations/0001_better_auth.sql -y",
    "db:migrate:local": "wrangler d1 migrations apply klef-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply klef-db --remote",
    "cf-typegen": "wrangler types"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@better-auth/passkey": "^1.6.23",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hash-wasm": "^4.12.0",
    "hono": "^4.12.30",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-easy-crop": "^6.2.2",
    "react-resizable-panels": "^3.0.6",
    "react-router": "^8.2.0",
    "shadcn": "^4.13.0",
    "simple-icons": "^16.26.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.44.0",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@fontsource/inter": "^5.3.0",
    "@fontsource/jetbrains-mono": "^5.3.0",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "happy-dom": "^20.10.6",
    "satori": "^0.28.2",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
