{
  "name": "klef",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Personal, zero-knowledge, end-to-end-encrypted .env sync. Self-hostable on Cloudflare.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler deploy",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "better-auth generate --config ./auth-cli.ts --output ./migrations/0001_better_auth.sql -y",
    "db:migrate:local": "wrangler d1 migrations apply klef-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply klef-db --remote",
    "cf-typegen": "wrangler types"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "@better-auth/passkey": "^1.6.22",
    "better-auth": "^1.6.22",
    "hash-wasm": "^4.12.0",
    "hono": "^4.12.27",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/vitest-pool-workers": "^0.16.20",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "better-sqlite3": "^12.11.1",
    "happy-dom": "^20.10.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
